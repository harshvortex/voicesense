# VoiceSense Environment Variables
# Copy to .env and edit. Never commit your real .env file.

# ── Flask Configuration ────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False

# ── Supabase Configuration (REQUIRED for authentication & storage) ──────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Database Configuration (auto-filled by Supabase integration) ────────────────
POSTGRES_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.your-project.supabase.co

# ── ML Model Configuration (for local development only) ───────────────────────
WHISPER_MODEL=base
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# ── Demo Mode (set to true for Vercel serverless, false for local with ML) ──────
DEMO_MODE=true

# ── Upload Configuration ───────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Server Port (local development) ────────────────────────────────────────────
PORT=8000
