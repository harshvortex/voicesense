{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.11"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/api/index.py",
            "headers": {
                "Cache-Control": "public, max-age=3600, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.py"
        }
    ],
    "env": {
        "DEMO_MODE": "true",
        "FLASK_ENV": "production"
    },
    "buildCommand": "pip install -r requirements.txt",
    "outputDirectory": "."
}
